# Upstash Redis (https://upstash.com)
# Récupère ces valeurs dans la console Upstash > ta base > onglet "REST API"
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Note : si tu utilises l'intégration Vercel Marketplace (Upstash), elle peut
# créer les variables sous les noms KV_REST_API_URL / KV_REST_API_TOKEN.
# Le code accepte automatiquement ces deux jeux de noms, rien à changer.
